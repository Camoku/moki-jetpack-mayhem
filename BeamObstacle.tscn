; ==========================================================
;  BeamObstacle.tscn - a floating laser bar between two emitter caps
; ==========================================================
;  beam_obstacle.gd sizes these sprites into a capped beam (built
;  HORIZONTAL, then the node is rotated 90 deg for a vertical one):
;    CollisionShape2D <- the deadly box (covers the whole bar)
;    Beam             <- the green laser, stretched to the length
;    Cap1 / Cap2      <- the metal emitter caps on each end (Cap2 mirrored)
; ==========================================================

[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://beam_obstacle.gd" id="1_beam"]
[ext_resource type="SpriteFrames" path="res://sprites/hazards/lazer_beam_frames.tres" id="2_beam"]
[ext_resource type="Texture2D" uid="uid://dl4mtmgnic23r" path="res://sprites/hazards/lazer_cap.png" id="3_cap"]

[node name="BeamObstacle" type="Area2D"]
script = ExtResource("1_beam")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]

[node name="Beam" type="AnimatedSprite2D" parent="."]
texture_filter = 1
sprite_frames = ExtResource("2_beam")
animation = &"crackle"
autoplay = "crackle"

[node name="Cap1" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("3_cap")

[node name="Cap2" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("3_cap")
flip_h = true
