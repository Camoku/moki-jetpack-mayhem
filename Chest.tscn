; ==========================================================
;  Chest.tscn - the reward chest you fly over to claim
; ==========================================================
;  chest.gd picks the art by the `big` flag: a normal chest, or the fancier
;  GRAND (boss) chest. The chest opens/closes (2-frame "idle") and has a gold
;  glow so it reads as an enticing reward.
;    CollisionShape2D <- the pickup area
;    Glow             <- gold danger/treasure glow
;    Sprite           <- the animated chest (closed <-> open)
; ==========================================================

[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://chest.gd" id="1_chest"]
[ext_resource type="SpriteFrames" path="res://sprites/chests/chest_frames.tres" id="2_frames"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_chest"]
size = Vector2(64, 56)

[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex_chest"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[node name="Chest" type="Area2D"]
script = ExtResource("1_chest")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_chest")

[node name="Glow" type="PointLight2D" parent="."]
color = Color(1, 0.85, 0.35, 1)
energy = 1.1
texture = SubResource("GlowTex_chest")
texture_scale = 0.6

[node name="Sprite" type="AnimatedSprite2D" parent="."]
texture_filter = 1
scale = Vector2(0.115, 0.115)
sprite_frames = ExtResource("2_frames")
animation = &"idle"
autoplay = "idle"
