; ==========================================================
;  Chest.tscn - the RISK survival reward pickup
; ==========================================================
;  Tree:
;    Chest (Area2D)         <- detector, runs chest.gd
;    +-- CollisionShape2D   <- the pickup area
;    +-- Body  (ColorRect)  <- brown chest body
;    +-- Lid   (ColorRect)  <- gold lid strip
;    +-- Latch (ColorRect)  <- little gold latch
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://chest.gd" id="1_chest"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_chest"]
size = Vector2(64, 56)

[node name="Chest" type="Area2D"]
script = ExtResource("1_chest")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_chest")

[node name="Body" type="ColorRect" parent="."]
offset_left = -32.0
offset_top = -12.0
offset_right = 32.0
offset_bottom = 28.0
color = Color(0.5, 0.32, 0.16, 1)

[node name="Lid" type="ColorRect" parent="."]
offset_left = -32.0
offset_top = -28.0
offset_right = 32.0
offset_bottom = -10.0
color = Color(1, 0.82, 0.2, 1)

[node name="Latch" type="ColorRect" parent="."]
offset_left = -7.0
offset_top = -14.0
offset_right = 7.0
offset_bottom = 6.0
color = Color(1, 0.9, 0.4, 1)
