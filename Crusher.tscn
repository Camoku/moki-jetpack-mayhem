; ==========================================================
;  Crusher.tscn - a gate whose two blocks slam open and shut
; ==========================================================
;  The block sizes/positions are all set in code (crusher.gd) from its
;  @export cycle settings. The two blocks are TextureRects tiling the
;  green tech-panel floor texture, so the gate looks like solid machinery.
;
;  Tree:
;    Crusher (Area2D)         <- detector, runs crusher.gd
;    +-- TopShape    (CollisionShape2D)  <- ceiling block hit box
;    +-- BottomShape (CollisionShape2D)  <- floor block hit box
;    +-- TopWall     (TextureRect)       <- ceiling block visual (tiled floor tex)
;    +-- BottomWall  (TextureRect)       <- floor block visual (tiled floor tex)
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://crusher.gd" id="1_crush"]
[ext_resource type="Texture2D" uid="uid://b3mleqq70w7n3" path="res://sprites/hazards/crusher_tex.png" id="2_floor"]

[node name="Crusher" type="Area2D"]
script = ExtResource("1_crush")

[node name="TopShape" type="CollisionShape2D" parent="."]

[node name="BottomShape" type="CollisionShape2D" parent="."]

[node name="TopWall" type="TextureRect" parent="."]
texture_filter = 1
texture = ExtResource("2_floor")
expand_mode = 1
stretch_mode = 1

[node name="BottomWall" type="TextureRect" parent="."]
texture_filter = 1
texture = ExtResource("2_floor")
expand_mode = 1
stretch_mode = 1
