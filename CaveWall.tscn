; ==========================================================
;  CaveWall.tscn - one vertical slice of the cave tunnel
; ==========================================================
;  cave_wall.gd builds a top and bottom rock wall with a gap between
;  them. The spawner streams many of these close together, with the
;  gap snaking up and down, to form a continuous winding tunnel.
;
;    TopShape / BottomShape   <- collision for the two wall blocks
;    TopWall  / BottomWall     <- the rock visuals
; ==========================================================

[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://cave_wall.gd" id="1_cw"]

[node name="CaveWall" type="Area2D"]
script = ExtResource("1_cw")

[node name="TopShape" type="CollisionShape2D" parent="."]

[node name="BottomShape" type="CollisionShape2D" parent="."]

[node name="TopWall" type="ColorRect" parent="."]
color = Color(0.42, 0.39, 0.46, 1)

[node name="BottomWall" type="ColorRect" parent="."]
color = Color(0.42, 0.39, 0.46, 1)
