# Godot 4+ .gitignore

# Godot-imported assets cache (regenerated on open)
.godot/

# Exported builds
/build/
*.exe
*.pck
*.zip

# ...but DO publish the web build that GitHub Pages serves (overrides the
# *.pck ignore above so the game data ships).
!/docs/
!/docs/**

# OS / editor cruft
.DS_Store
Thumbs.db
