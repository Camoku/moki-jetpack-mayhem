; ==========================================================
;  Main.tscn - the whole game scene laid out as text.
;
;  Node tree:
;    Main (Node2D)                        <- the root
;    +-- Background (ParallaxBackground)  <- auto-follows the Camera
;    |    +-- SpaceLayer  (ParallaxLayer) <- solid black backdrop (pinned)
;    |    +-- StarsFar    (ParallaxLayer) <- dim stars, drift slowly
;    |    +-- StarsNear   (ParallaxLayer) <- bright stars, drift faster
;    |    +-- FloorLayer  (ParallaxLayer) <- uniform floor (never pops)
;    +-- Player (CharacterBody2D)         <- the Moki (runs player.gd)
;         +-- CollisionShape2D            <- its physical body
;         +-- Sprite2D                    <- the orange placeholder
;         +-- Camera2D                    <- follows X, LOCKED on Y
;
;  Key idea this version teaches:
;    The camera is locked vertically (limit_top/limit_bottom), so the
;    screen always shows world Y 0..720. That means:
;      - world Y 0   = TOP of the screen (the roof)
;      - world Y 720 = BOTTOM of the screen (the floor)
;    A uniform floor pinned down there can NEVER pop, and we can clamp
;    the Moki between roof and floor so it never leaves the screen.
; ==========================================================

[gd_scene load_steps=28 format=3]

[ext_resource type="Script" path="res://player.gd" id="1_player"]
[ext_resource type="Script" path="res://darkness.gd" id="15_darkness"]
[ext_resource type="PackedScene" path="res://Boss.tscn" id="16_boss"]
[ext_resource type="PackedScene" path="res://BounceOrb.tscn" id="17_orb"]
