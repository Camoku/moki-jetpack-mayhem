; The Moki's physical collision box: a 64x64 rectangle.
[sub_resource type="RectangleShape2D" id="RectangleShape2D_box"]
size = Vector2(64, 64)

; A tiny color ramp that is orange at BOTH ends -> a flat orange texture.
[sub_resource type="Gradient" id="Gradient_orange"]
colors = PackedColorArray(1, 0.55, 0.1, 1, 1, 0.55, 0.1, 1)

; A 64x64 solid-orange texture for the Sprite2D (no image file needed).
[sub_resource type="GradientTexture2D" id="GradientTexture2D_orange"]
gradient = SubResource("Gradient_orange")
width = 64
height = 64

; A soft round glow (white centre -> transparent edge) for the Moki's faint
; "I can just about see myself" light during a blackout.
[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex_player"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

; ---------------- ROOT ----------------
[node name="Main" type="Node2D"]

; ---------------- DARKNESS (Blackout event) ----------------
; A CanvasModulate that dims the whole world. White by default (no effect);
; darkness.gd slides it toward near-black during the Blackout event. The HUD
; (a separate CanvasLayer) and the 2D glow lights are unaffected, so in the
; dark you only see the coins shine and the hazards glow.
[node name="Darkness" type="CanvasModulate" parent="."]
script = ExtResource("15_darkness")

; ---------------- BACKGROUND ----------------
[node name="Background" type="ParallaxBackground" parent="."]

; The background is its OWN CanvasLayer (ParallaxBackground extends
; CanvasLayer), so the root Darkness can't reach it. This second copy dims
; the stars and floor in lock-step, so the WHOLE scene goes dark together.
[node name="Darkness" type="CanvasModulate" parent="Background"]
script = ExtResource("15_darkness")

; --- Solid black space backdrop ---
; motion_scale (0,0) = "ignore the camera", so this just fills the screen.
[node name="SpaceLayer" type="ParallaxLayer" parent="Background"]
motion_scale = Vector2(0, 0)

[node name="Space" type="ColorRect" parent="Background/SpaceLayer"]
offset_left = -200.0
offset_top = -200.0
offset_right = 1480.0
offset_bottom = 920.0
color = Color(0.02, 0.02, 0.06, 1)
script = ExtResource("2_bg")

; --- Far stars (deep space) ---
; Drift slowly (motion_scale 0.2) and tile every 1280px (motion_mirroring).
; Because the stars tile, they go on forever; because each one is tiny,
; them sliding past the edge reads as "starfield motion", not a hard seam.
[node name="StarsFar" type="ParallaxLayer" parent="Background"]
motion_scale = Vector2(0.2, 1)
motion_mirroring = Vector2(1280, 0)

