; --- The FLOOR ---
; The key change: motion_scale (0,0) PINS this to the screen (exactly like
; the black backdrop), so the floor does NOT scroll or tile at all. It is
; one solid strip across the whole screen width -> perfectly consistent,
; with zero chance of a tiling seam ever showing up.
[node name="FloorLayer" type="ParallaxLayer" parent="Background"]
motion_scale = Vector2(0, 0)

[node name="FloorBase" type="ColorRect" parent="Background/FloorLayer"]
offset_left = -100.0
offset_top = 660.0
offset_right = 1380.0
offset_bottom = 720.0
color = Color(0.12, 0.13, 0.18, 1)

[node name="FloorEdge" type="ColorRect" parent="Background/FloorLayer"]
offset_left = -100.0
offset_top = 660.0
offset_right = 1380.0
offset_bottom = 666.0
color = Color(0.3, 0.55, 0.7, 1)

; ---------------- PLAYER (the Moki) ----------------
[node name="Player" type="CharacterBody2D" parent="."]
position = Vector2(200, 300)
script = ExtResource("1_player")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Player"]
shape = SubResource("RectangleShape2D_box")

[node name="Sprite2D" type="Sprite2D" parent="Player"]
texture = SubResource("GradientTexture2D_orange")

; The jetpack: a small grey tank mounted on the Moki's back (left side,
; since the Moki always faces right).
[node name="Jetpack" type="ColorRect" parent="Player"]
offset_left = -46.0
offset_top = -18.0
offset_right = -28.0
offset_bottom = 22.0
color = Color(0.45, 0.45, 0.52, 1)

; The flame shoots out the bottom of the jetpack. It starts hidden and
; player.gd flips it visible only while the boost button is held.
[node name="Flame" type="ColorRect" parent="Player"]
visible = false
offset_left = -44.0
offset_top = 22.0
offset_right = -30.0
offset_bottom = 60.0
color = Color(1, 0.7, 0.1, 1)

; A translucent force-field bubble, shown only while a Shield is active.
[node name="Shield" type="ColorRect" parent="Player"]
visible = false
offset_left = -46.0
offset_top = -46.0
offset_right = 46.0
offset_bottom = 46.0
color = Color(0.3, 0.7, 1, 0.3)

; The Moki's own faint glow (think: the jetpack flame's light). Off in normal
; play; player.gd raises it during a blackout so you can just make yourself
; out in the dark - dim on purpose, so it stays tense.
[node name="Glow" type="PointLight2D" parent="Player"]
energy = 0.0
color = Color(1, 0.6, 0.25, 1)
texture = SubResource("GlowTex_player")
texture_scale = 1.6

; ---------------- CAMERA (world auto-scroller) ----------------
; The camera is its OWN node now (not a child of the Player). camera.gd
; slides it right at a constant speed, which is what scrolls the world.
; limit_top/limit_bottom lock the vertical view to world Y 0..720, so the
; floor stays pinned to the bottom of the screen. It starts centred at
; (640, 360) so the very first view is world X 0..1280, Y 0..720.
[node name="Camera" type="Camera2D" parent="."]
position = Vector2(640, 360)
limit_top = 0
limit_bottom = 720
script = ExtResource("7_camera")

; ---------------- OBSTACLE SPAWNER ----------------
; A plain Node2D that runs spawner.gd. It has no visuals itself - its job
; is just to drop asteroid copies into the world as the Moki flies.
[node name="ObstacleSpawner" type="Node2D" parent="."]
script = ExtResource("4_spawner")
obstacle_scene = ExtResource("3_obstacle")
vertical_laser_scene = ExtResource("5_vlaser")
horizontal_laser_scene = ExtResource("6_hlaser")
coin_scene = ExtResource("9_coin")
powerup_scene = ExtResource("10_powerup")
beam_obstacle_scene = ExtResource("11_beam")
ring_scene = ExtResource("12_ring")
missile_scene = ExtResource("13_missile")
cave_wall_scene = ExtResource("14_cavewall")
boss_scene = ExtResource("16_boss")
orb_scene = ExtResource("17_orb")
crusher_scene = ExtResource("18_crusher")
drone_scene = ExtResource("19_drone")
fireworks_scene = ExtResource("20_fireworks")
chest_scene = ExtResource("21_chest")
spin_token_scene = ExtResource("22_spintoken")

; ---------------- HUD (score + game over) ----------------
; A CanvasLayer draws in screen space (stays put as the world scrolls).
; process_mode = 3 is "Always", so it keeps running while the game is
; paused on the game-over screen - that is how it catches the retry key.
[node name="HUD" type="CanvasLayer" parent="."]
process_mode = 3
script = ExtResource("8_hud")

; Full-screen celebration flash (hidden until hud.flash() pops it). First child
; so it flashes over the world but sits behind the score readouts.
[node name="Flash" type="ColorRect" parent="HUD"]
visible = false
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(1, 1, 1, 0)
mouse_filter = 2

[node name="DistanceLabel" type="Label" parent="HUD"]
offset_left = 24.0
offset_top = 16.0
offset_right = 360.0
offset_bottom = 56.0
theme_override_font_sizes/font_size = 30
text = "Distance: 0 m"

[node name="MultLabel" type="Label" parent="HUD"]
offset_left = 24.0
offset_top = 54.0
offset_right = 360.0
offset_bottom = 82.0
theme_override_font_sizes/font_size = 20
text = "Multiplier: x1.0"

[node name="CoinLabel" type="Label" parent="HUD"]
