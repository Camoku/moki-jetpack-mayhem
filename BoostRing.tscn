; ==========================================================
;  BoostRing.tscn - fly through it for a speed boost
; ==========================================================
;  A square "ring" made of four glowing bars (visual only). The
;  CollisionShape2D is the OPENING in the middle, so you trigger it by
;  flying through the centre. Not a hazard - the bars never hurt you.
;
;  Neon-green styled to match the speed-gate (Dash) powerup: each edge is
;  a vivid lime bar with a brighter white-green inner "tube" highlight,
;  and a green PointLight2D halo blooms around the whole frame.
; ==========================================================

[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://ring.gd" id="1_ring"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_ring"]
size = Vector2(70, 70)

; White radial used as the PointLight2D texture for the green neon halo.
[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[node name="BoostRing" type="Area2D"]
script = ExtResource("1_ring")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_ring")

; A green halo so the frame reads as a glowing neon gate.
[node name="Glow" type="PointLight2D" parent="."]
color = Color(0.35, 1, 0.62, 1)
energy = 1.2
texture = SubResource("GlowTex")
texture_scale = 0.75

; --- The four edge "tubes" (vivid lime body). ---
[node name="Top" type="ColorRect" parent="."]
offset_left = -48.0
offset_top = -48.0
offset_right = 48.0
offset_bottom = -36.0
color = Color(0.35, 1, 0.6, 1)

[node name="Bottom" type="ColorRect" parent="."]
offset_left = -48.0
offset_top = 36.0
offset_right = 48.0
offset_bottom = 48.0
color = Color(0.35, 1, 0.6, 1)

[node name="Left" type="ColorRect" parent="."]
offset_left = -48.0
offset_top = -48.0
offset_right = -36.0
offset_bottom = 48.0
color = Color(0.35, 1, 0.6, 1)

[node name="Right" type="ColorRect" parent="."]
offset_left = 36.0
offset_top = -48.0
offset_right = 48.0
offset_bottom = 48.0
color = Color(0.35, 1, 0.6, 1)

; --- Bright white-green inner highlights (the hot neon "core" edge). ---
[node name="TopHi" type="ColorRect" parent="."]
offset_left = -46.0
offset_top = -39.0
offset_right = 46.0
offset_bottom = -36.0
color = Color(0.8, 1, 0.88, 1)

[node name="BottomHi" type="ColorRect" parent="."]
offset_left = -46.0
offset_top = 36.0
offset_right = 46.0
offset_bottom = 39.0
color = Color(0.8, 1, 0.88, 1)

[node name="LeftHi" type="ColorRect" parent="."]
offset_left = -39.0
offset_top = -46.0
offset_right = -36.0
offset_bottom = 46.0
color = Color(0.8, 1, 0.88, 1)

[node name="RightHi" type="ColorRect" parent="."]
offset_left = 36.0
offset_top = -46.0
offset_right = 39.0
offset_bottom = 46.0
color = Color(0.8, 1, 0.88, 1)
