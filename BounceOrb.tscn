; ==========================================================
;  BounceOrb.tscn - a plasma ball that bounces between roof and floor
; ==========================================================
;  Tree:
;    BounceOrb (Area2D)       <- detector, runs bounce_orb.gd
;    +-- CollisionShape2D     <- 40x40 hit box
;    +-- Glow (PointLight2D)  <- purple halo (pulsed in code)
;    +-- Sprite (Sprite2D)    <- the glowing purple plasma orb (spun in code)
; ==========================================================

[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://bounce_orb.gd" id="1_orb"]
[ext_resource type="Texture2D" path="res://sprites/hazards/purple_orb.png" id="2_tex"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_orb"]
size = Vector2(40, 40)

[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[node name="BounceOrb" type="Area2D"]
script = ExtResource("1_orb")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_orb")

[node name="Glow" type="PointLight2D" parent="."]
color = Color(0.7, 0.35, 1, 1)
energy = 1.1
texture = SubResource("GlowTex")
texture_scale = 0.45

[node name="Sprite" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("2_tex")
scale = Vector2(0.1, 0.1)
