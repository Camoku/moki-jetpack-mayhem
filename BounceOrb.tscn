; ==========================================================
;  BounceOrb.tscn - a ball that bounces between roof and floor
; ==========================================================
;  Tree:
;    BounceOrb (Area2D)       <- detector, runs bounce_orb.gd
;    +-- CollisionShape2D     <- 40x40 hit box
;    +-- Ball   (ColorRect)   <- the purple orb
;    +-- Shine  (ColorRect)   <- a lighter highlight for charm
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://bounce_orb.gd" id="1_orb"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_orb"]
size = Vector2(40, 40)

[node name="BounceOrb" type="Area2D"]
script = ExtResource("1_orb")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_orb")

[node name="Ball" type="ColorRect" parent="."]
offset_left = -20.0
offset_top = -20.0
offset_right = 20.0
offset_bottom = 20.0
color = Color(0.6, 0.3, 1, 1)

[node name="Shine" type="ColorRect" parent="."]
offset_left = -12.0
offset_top = -14.0
offset_right = -2.0
offset_bottom = -4.0
color = Color(0.85, 0.72, 1, 1)
