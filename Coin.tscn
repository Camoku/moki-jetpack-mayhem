; ==========================================================
;  Coin.tscn - one collectible gold coin
; ==========================================================
;  Same idea as an asteroid (an Area2D that detects the Moki), but
;  instead of crashing you, it gives you a coin and vanishes.
;
;  Tree:
;    Coin (Area2D)        <- detector, runs coin.gd
;    +-- CollisionShape2D <- the pickup area
;    +-- Outer (ColorRect)<- gold square
;    +-- Inner (ColorRect)<- lighter gold centre
; ==========================================================

[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://coin.gd" id="1_coin"]
[ext_resource type="SpriteFrames" path="res://sprites/coins/coin_frames.tres" id="2_coinframes"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_coin"]
size = Vector2(34, 34)

; A soft round glow: white in the middle fading to transparent at the edge.
; This is the LIGHT TEXTURE the coin's glow shines through in the dark.
[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex_coin"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[node name="Coin" type="Area2D"]
script = ExtResource("1_coin")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_coin")

; The spinning gold coin (replaces the old flat gold squares). The art is ~150px,
; so scale ~0.25 brings it down to ~38px (about the old coin size). Smooth art, so
; we leave the default Linear filter (no Nearest). coin.gd randomises the start
; frame so a field of coins doesn't spin in lock-step.
[node name="Sprite" type="AnimatedSprite2D" parent="."]
scale = Vector2(0.25, 0.25)
sprite_frames = ExtResource("2_coinframes")
animation = &"spin"
autoplay = "spin"

; The coin's gold shine. energy starts at 0 (invisible in normal play);
; coin.gd cranks it up with GameState.blackout so it only glows in the dark.
[node name="Glow" type="PointLight2D" parent="."]
energy = 0.0
color = Color(1, 0.85, 0.3, 1)
texture = SubResource("GlowTex_coin")
texture_scale = 0.7
