; ==========================================================
;  Coin.tscn - one collectible gold coin
; ==========================================================
;  Same idea as an asteroid (an Area2D that detects the Moki), but
;  instead of crashing you, it gives you a coin and vanishes.
;
;  Tree:
;    Coin (Area2D)        <- detector, runs coin.gd
;    +-- CollisionShape2D <- the pickup area
;    +-- Outer (ColorRect)<- gold square
;    +-- Inner (ColorRect)<- lighter gold centre
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://coin.gd" id="1_coin"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_coin"]
size = Vector2(34, 34)

[node name="Coin" type="Area2D"]
script = ExtResource("1_coin")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_coin")

[node name="Outer" type="ColorRect" parent="."]
offset_left = -18.0
offset_top = -18.0
offset_right = 18.0
offset_bottom = 18.0
color = Color(1, 0.82, 0.2, 1)

[node name="Inner" type="ColorRect" parent="."]
offset_left = -10.0
offset_top = -10.0
offset_right = 10.0
offset_bottom = 10.0
color = Color(1, 0.93, 0.55, 1)
