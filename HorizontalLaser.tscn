; ==========================================================
;  HorizontalLaser.tscn - a full-width sweeping beam (now a crackling RED beam)
; ==========================================================
;  horizontal_laser.gd sizes these to span the whole screen width, matching the
;  floating BeamObstacle's look (animated energy beam + emitter caps), but red:
;    CollisionShape2D <- the deadly box
;    Beam             <- the red crackling laser (AnimatedSprite2D)
;    Cap1 / Cap2      <- emitter caps at the left + right ends (Cap2 mirrored)
; ==========================================================

[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://horizontal_laser.gd" id="1_hl"]
[ext_resource type="SpriteFrames" path="res://sprites/hazards/lazer_beam_red_frames.tres" id="2_beam"]
[ext_resource type="Texture2D" path="res://sprites/hazards/lazer_cap.png" id="3_cap"]

[node name="HorizontalLaser" type="Area2D"]
script = ExtResource("1_hl")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]

[node name="Beam" type="AnimatedSprite2D" parent="."]
texture_filter = 1
sprite_frames = ExtResource("2_beam")
animation = &"crackle"
autoplay = "crackle"

[node name="Cap1" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("3_cap")

[node name="Cap2" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("3_cap")
