; ==========================================================
;  Missile.tscn - a missile that flies in from the right
; ==========================================================
;  missile.gd runs it in two stages: it hovers at the right edge
;  flashing a circular "!" warning at its height, then launches left.
;
;    CollisionShape2D <- the deadly box
;    Body / Tip       <- the missile visual (hidden until launch)
;    WarnBg (Panel)   <- white circle + red ring behind the "!"
;      +-- Warn       <- the red "!" itself
; ==========================================================

[gd_scene load_steps=7 format=3]

[ext_resource type="Script" path="res://missile.gd" id="1_missile"]
[ext_resource type="SpriteFrames" path="res://sprites/hazards/missile_frames.tres" id="2_missile"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_missile"]
size = Vector2(52, 22)

; A soft radial (white centre -> clear) used as the missile's danger-glow light.
[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex_missile"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_warn"]
bg_color = Color(1, 1, 1, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
border_color = Color(1, 0.25, 0.2, 1)
corner_radius_top_left = 26
corner_radius_top_right = 26
corner_radius_bottom_right = 26
corner_radius_bottom_left = 26

[node name="Missile" type="Area2D"]
script = ExtResource("1_missile")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_missile")

; The missile art (replaces the orange Body+Tip rectangles): points LEFT with its
; green exhaust trailing right, and the exhaust FLICKERS (4-frame "fly" anim).
; Hidden until launch. position.x nudges it so the missile BODY sits over the
; collision box (the flame trails past it harmlessly).
[node name="Sprite" type="AnimatedSprite2D" parent="."]
texture_filter = 1
position = Vector2(17, 0)
scale = Vector2(0.2366, 0.2366)
sprite_frames = ExtResource("2_missile")
animation = &"fly"
autoplay = "fly"

; A pulsing red danger glow (missile.gd shows + pulses it on launch) so the
; missile pops against the green city background.
[node name="Glow" type="PointLight2D" parent="."]
visible = false
color = Color(1, 0.35, 0.2, 1)
energy = 1.3
texture = SubResource("GlowTex_missile")
texture_scale = 0.5

[node name="WarnBg" type="Panel" parent="."]
offset_left = -26.0
offset_top = -26.0
offset_right = 26.0
offset_bottom = 26.0
theme_override_styles/panel = SubResource("StyleBoxFlat_warn")

[node name="Warn" type="Label" parent="WarnBg"]
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_colors/font_color = Color(1, 0.25, 0.2, 1)
theme_override_font_sizes/font_size = 40
text = "!"
horizontal_alignment = 1
vertical_alignment = 1
