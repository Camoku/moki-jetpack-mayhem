; ==========================================================
;  Drone.tscn - a small homing enemy (a green homing MISSILE)
; ==========================================================
;  Tree:
;    Drone (Area2D)           <- detector, runs drone.gd
;    +-- CollisionShape2D     <- 34x28 hit box (the lethal body; nose/flame
;                                extend past it harmlessly)
;    +-- Sprite (AnimatedSprite2D) <- the missile art, flame flickering, nose
;                                left (its travel direction); drone.gd tilts it
;                                toward whoever it is tracking.
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://drone.gd" id="1_drone"]
[ext_resource type="SpriteFrames" path="res://sprites/hazards/homing_missile_frames.tres" id="2_frames"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_drone"]
size = Vector2(34, 28)

[node name="Drone" type="Area2D"]
script = ExtResource("1_drone")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_drone")

[node name="Sprite" type="AnimatedSprite2D" parent="."]
texture_filter = 1
sprite_frames = ExtResource("2_frames")
animation = &"fly"
offset = Vector2(8, -1)
scale = Vector2(0.22, 0.22)
