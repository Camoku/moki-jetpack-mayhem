; ==========================================================
;  Drone.tscn - a small homing enemy
; ==========================================================
;  Tree:
;    Drone (Area2D)           <- detector, runs drone.gd
;    +-- CollisionShape2D     <- 34x28 hit box
;    +-- Body (ColorRect)     <- the red drone shell
;    +-- Eye  (ColorRect)     <- a glowing eye (charm + reads as "enemy")
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://drone.gd" id="1_drone"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_drone"]
size = Vector2(34, 28)

[node name="Drone" type="Area2D"]
script = ExtResource("1_drone")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_drone")

[node name="Body" type="ColorRect" parent="."]
offset_left = -17.0
offset_top = -14.0
offset_right = 17.0
offset_bottom = 14.0
color = Color(0.75, 0.2, 0.25, 1)

[node name="Eye" type="ColorRect" parent="."]
offset_left = -3.0
offset_top = -5.0
offset_right = 9.0
offset_bottom = 5.0
color = Color(1, 0.85, 0.3, 1)
