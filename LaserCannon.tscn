; ==========================================================
;  LaserCannon.tscn - the Laser Cannon mini-boss
; ==========================================================
;  A ceiling-mounted turret that hangs at the top of the screen and
;  rides along with the camera (screen-locked, like the lasers). It
;  runs laser_cannon.gd, which drives the whole fight:
;    INTRO -> (ATTACK <-> OVERHEAT) -> DYING / RETREAT
;
;  Tree:
;    LaserCannon (Node2D)        <- the boss brain (laser_cannon.gd)
;    +-- Housing (ColorRect)     <- the turret body (decorative, NOT deadly)
;    +-- Barrel  (ColorRect)     <- a stub pointing down (decorative)
;    +-- Core (Area2D)           <- the WEAK POINT you fly into to damage it
;         +-- CoreShape          <- its touch area
;         +-- CoreRect           <- the glowing square (red=sealed, hot=exposed)
;
;  Only the cannon's BEAMS are deadly; the housing is just scenery and the
;  core is beneficial - so there is no cheap "you touched the boss = dead".
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://laser_cannon.gd" id="1_cannon"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_core"]
size = Vector2(72, 72)

[node name="LaserCannon" type="Node2D"]
script = ExtResource("1_cannon")

[node name="Housing" type="ColorRect" parent="."]
offset_left = -120.0
offset_top = 0.0
offset_right = 120.0
offset_bottom = 64.0
color = Color(0.3, 0.32, 0.4, 1)

[node name="Barrel" type="ColorRect" parent="."]
offset_left = -26.0
offset_top = 64.0
offset_right = 26.0
offset_bottom = 108.0
color = Color(0.22, 0.23, 0.3, 1)

; The weak point, hanging below the barrel in reachable play space.
[node name="Core" type="Area2D" parent="."]
position = Vector2(0, 152)

[node name="CoreShape" type="CollisionShape2D" parent="Core"]
shape = SubResource("RectangleShape2D_core")

[node name="CoreRect" type="ColorRect" parent="Core"]
offset_left = -36.0
offset_top = -36.0
offset_right = 36.0
offset_bottom = 36.0
color = Color(0.5, 0.15, 0.15, 1)
