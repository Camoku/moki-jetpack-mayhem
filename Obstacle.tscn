; ==========================================================
;  Obstacle.tscn - one reusable asteroid
; ==========================================================
;  The spawner makes copies of this scene at runtime.
;
;  Tree:
;    Obstacle (Area2D)        <- the detector, runs obstacle.gd
;    +-- CollisionShape2D     <- the area's shape (56x56 box)
;    +-- Rock   (ColorRect)   <- the asteroid body
;    +-- Crater (ColorRect)   <- a little darker detail for charm
; ==========================================================

[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://obstacle.gd" id="1_obs"]
[ext_resource type="Texture2D" uid="uid://bu15dbksma0l1" path="res://sprites/asteroid_brown.png" id="2_ast"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_rock"]
size = Vector2(56, 56)

; A soft round glow texture (white centre fading to clear), shared by the
; asteroid's warning light in the dark.
[sub_resource type="Gradient" id="Gradient_glow"]
offsets = PackedFloat32Array(0, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GlowTex_rock"]
gradient = SubResource("Gradient_glow")
width = 256
height = 256
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(0.5, 0)

[node name="Obstacle" type="Area2D"]
script = ExtResource("1_obs")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_rock")

; The asteroid art (replaces the old grey rectangles). Pixel art, so Nearest
; filter; scaled ~0.42 so the ~150px rock sits a touch larger than the 56px
; hitbox (fair - the visual covers the collision). obstacle.gd gives each copy a
; random orientation, flip, and slow tumble so they don't all look identical.
[node name="Sprite" type="Sprite2D" parent="."]
texture_filter = 1
texture = ExtResource("2_ast")
scale = Vector2(0.52, 0.52)

; The asteroid's danger glow - a menacing red-orange. Off (energy 0) in
; normal play; obstacle.gd lights it up with GameState.blackout.
[node name="Glow" type="PointLight2D" parent="."]
energy = 0.0
color = Color(1, 0.35, 0.2, 1)
texture = SubResource("GlowTex_rock")
texture_scale = 0.95
