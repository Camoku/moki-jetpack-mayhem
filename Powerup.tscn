; ==========================================================
;  Powerup.tscn - one reusable powerup pickup
; ==========================================================
;  ONE scene handles every kind of powerup. powerup.gd reads its
;  "type" and styles itself (colour + letter) to match. To add a new
;  powerup later you mostly just add a case in the code - no new scene.
;
;  Tree:
;    Powerup (Area2D)     <- detector, runs powerup.gd
;    +-- CollisionShape2D <- the pickup area
;    +-- Box (ColorRect)  <- coloured badge
;    +-- Label            <- the icon letter (e.g. "S" for Shield)
; ==========================================================

[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://powerup.gd" id="1_pu"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_pu"]
size = Vector2(46, 46)

[node name="Powerup" type="Area2D"]
script = ExtResource("1_pu")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("RectangleShape2D_pu")

[node name="Box" type="ColorRect" parent="."]
offset_left = -24.0
offset_top = -24.0
offset_right = 24.0
offset_bottom = 24.0
color = Color(0.3, 0.7, 1, 1)

[node name="Label" type="Label" parent="."]
offset_left = -24.0
offset_top = -26.0
offset_right = 24.0
offset_bottom = 24.0
theme_override_colors/font_color = Color(0.1, 0.1, 0.15, 1)
theme_override_font_sizes/font_size = 28
text = "S"
horizontal_alignment = 1
vertical_alignment = 1
